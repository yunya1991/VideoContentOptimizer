# VideoContentOptimizer 环境配置

# LLM 配置
LLM_PROVIDER=deepseek
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Whisper 配置
WHISPER_MODEL_SIZE=base  # tiny, base, small, medium, large
WHISPER_DEVICE=cpu  # cpu 或 cuda
WHISPER_COMPUTE_TYPE=int8  # int8, float16, float32

# 视频处理配置
FFMPEG_PATH=/usr/bin/ffmpeg
TEMP_DIR=/tmp/video_optimizer
MAX_VIDEO_SIZE_MB=500
ALLOWED_EXTENSIONS=mp4,mov,avi,mkv

# 存储配置
STORAGE_TYPE=local  # local 或 s3
LOCAL_STORAGE_PATH=./storage
# S3_BUCKET_NAME=your-bucket-name
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# Redis 配置（任务队列）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# PostgreSQL 配置（结果存储）
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=videooptimizer
POSTGRES_USER=admin
POSTGRES_PASSWORD=password

# Web UI 配置
STREAMLIT_PORT=8501
STREAMLIT_THEME=light

# API 配置
API_HOST=0.0.0.0
API_PORT=8080
API_DEBUG=true

# 平台配置
DEFAULT_PLATFORM=douyin
ENABLE_CROSS_PLATFORM=true

# 批处理配置
BATCH_SIZE=4
PARALLEL_WORKERS=2
MAX_BATCH_VIDEOS=50

# 日志配置
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FILE=./logs/video_optimizer.log

# 安全配置 —— 请替换为你自己的强密钥（`python -c "import secrets; print(secrets.token_hex(32))"`）
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET=your-jwt-secret-here
TOKEN_EXPIRE_HOURS=24

# 功能开关
ENABLE_AUDIO_TRANSCRIPTION=true
ENABLE_VISUAL_ANALYSIS=true
ENABLE_LLM_OPTIMIZATION=true
ENABLE_PLATFORM_ADAPTATION=true
ENABLE_BATCH_PROCESSING=true
ENABLE_A_B_TESTING=false

# 平台发布（upload-post.com）
# 支持: tiktok, youtube, instagram, facebook, twitter, linkedin, pinterest
# 本项目映射: douyin→tiktok; xiaohongshu/weixin 不支持，自动跳过
UPLOAD_POST_ENABLED=false
UPLOAD_POST_API_KEY=
UPLOAD_POST_USERNAME=
UPLOAD_POST_PLATFORMS=tiktok

# CDP 浏览器自动化上传（video-upload-browser Skill）
# 用于无 API 的平台：抖音/小红书/B站/微信视频号/YouTube/TikTok
# 部署方式：cd skill/video-upload-browser && bash scripts/setup.sh && bash scripts/start.sh
# 验证方式：curl http://127.0.0.1:9223/json/version
CDP_ENABLED=false
CDP_URL=http://127.0.0.1:9223
CDP_VIEWPORT_WIDTH=1920
CDP_VIEWPORT_HEIGHT=1080
CDP_UPLOAD_TIMEOUT=300
CDP_MAX_RETRY=3
CDP_RETRY_DELAY=2.0

# 监控配置
ENABLE_METRICS=true
METRICS_PORT=9090
